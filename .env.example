VLLM_URL=http://127.0.0.1:8080/v1
VLLM_MODEL_NAME=Qwen/Qwen3-Coder-Next
PROXY_PORT=8081
PROXY_CONFIG_PATH=./models.yaml
PROXY_REQUEST_LOG_PATH=./data/proxy_requests.jsonl
PROXY_METRICS_PATH=./data/proxy_metrics.json
MAX_REQUEST_BYTES=25165824
STREAM_INACTIVITY_TIMEOUT_SECONDS=300
FORCE_STREAM_USAGE=1
DEFAULT_CLIENT_PROFILE=generic
COPILOT_MAX_OUTPUT_TOKENS=4096
KILO_MAX_OUTPUT_TOKENS=4096
KILO_MAX_CONTEXT_TOKENS=131072
KILO_MAX_CONCURRENT_STREAMS=1
CIRCUIT_BREAKER_FAILURES=5
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
BACKEND_CONNECT_TIMEOUT_SECONDS=10
BACKEND_REQUEST_TIMEOUT_SECONDS=180
STRICT_UNSUPPORTED_PARAMS=1
